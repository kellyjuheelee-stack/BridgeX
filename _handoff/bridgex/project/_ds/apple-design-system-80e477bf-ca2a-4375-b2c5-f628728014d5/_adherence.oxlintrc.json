{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/forms/**",
              "components/layout/**",
              "components/navigation/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|disabled|href|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, children, disabled, href, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|dark-utility|pearl|store-hero)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'dark-utility' | 'pearl' | 'store-hero'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConfiguratorChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|sublabel|selected|onSelect|style|key|ref|className|style|children)$/]",
        "message": "<ConfiguratorChip> doesn't accept that prop. Declared props: label, sublabel, selected, onSelect, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:heading|links|key|ref|className|style|children)$/]",
        "message": "<FooterColumn> doesn't accept that prop. Declared props: heading, links."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlobalNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|logoSrc|style|key|ref|className|style|children)$/]",
        "message": "<GlobalNav> doesn't accept that prop. Declared props: items, logoSrc, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|label|size|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, label, size, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:surface|eyebrow|headline|tagline|primaryLabel|secondaryLabel|imageSrc|imageAlt|compact|children|style|key|ref|className|style|children)$/]",
        "message": "<ProductTile> doesn't accept that prop. Declared props: surface, eyebrow, headline, tagline, primaryLabel, secondaryLabel, imageSrc, imageAlt, compact, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductTile'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:light|parchment|dark|dark-2|dark-3)$/]",
        "message": "<ProductTile> surface must be one of 'light' | 'parchment' | 'dark' | 'dark-2' | 'dark-3'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: placeholder, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoreCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:imageSrc|imageAlt|eyebrow|name|price|linkLabel|href|style|key|ref|className|style|children)$/]",
        "message": "<StoreCard> doesn't accept that prop. Declared props: imageSrc, imageAlt, eyebrow, name, price, linkLabel, href, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SubNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|links|ctaLabel|onCta|style|key|ref|className|style|children)$/]",
        "message": "<SubNav> doesn't accept that prop. Declared props: category, links, ctaLabel, onCta, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|onDark|chevron|style|key|ref|className|style|children)$/]",
        "message": "<TextLink> doesn't accept that prop. Declared props: children, href, onDark, chevron, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
