// BridgeX — 수출 가능성 진단 Intake Form
//
// MVP는 SQLite. SQLite는 Prisma의 스칼라 배열(String[])과 Json 타입을 지원하지 않으므로
// 배열/객체 필드는 TEXT(String)에 JSON 문자열로 저장한다. (직렬화는 src/utils/serialize.js 담당)
//
// ── PostgreSQL 전환 방법 ────────────────────────────────────────────────
//   1) 아래 datasource provider 를 "postgresql" 로 변경
//   2) .env 의 DATABASE_URL 을 postgresql:// 로 변경
//   3) (선택) 배열 필드를 native String[] 로, JSON 필드를 Json 으로 바꾸고
//      src/utils/serialize.js 의 JSON_FIELDS 에서 제외하면 네이티브 타입 사용 가능
//   4) npx prisma migrate dev
// ────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ExportDiagnosisRequest {
  id String @id @default(cuid())

  // ── Step 1. 기본 정보 ──
  contactName        String
  companyName        String
  position           String?
  email              String
  phone              String
  homepageUrl        String?
  smartStoreUrl      String?
  instagramUrl       String?
  annualRevenueRange String?

  // ── Step 2. 제품 정보 ──
  productName              String
  productCategory          String
  productFiles             String? // JSON: [{ fileName, fileUrl, fileType }]
  hasInci                  String
  volumeAndPriceRange      String?
  isSellingInKorea         String
  monthlySalesOrBestSeller String?
  certifications           String // JSON: string[]
  euComplianceReadiness    String? // JSON: string[] (EU 규제 준비 현황)
  packagingReadiness       String? // JSON: string[] (PPWR 포장재 준비 현황)

  // ── Step 3. 수출 목표 및 현재 상태 ──
  targetCountries     String // JSON: string[]
  preferredChannels   String? // JSON: string[]
  exportExperience    String
  tradeFairExperience String?
  hasExistingBuyer    String
  painPoints          String // JSON: string[]

  // ── Step 4. 진단 상태 ──
  diagnosisStatus String  @default("submitted")
  diagnosisResult String? // JSON: 자동 진단 결과 (기본/훅용)
  adminMemo       String?

  // ── 상담 신청 (훅 → 컨설팅 전환) ──
  consultationRequested   Boolean   @default(false)
  consultationRequestedAt DateTime?

  // ── 컨설팅 진행 트랙 (관리자) ──
  consultingStage     String? // 현재 단계 key (booking..contract)
  consultingChecklist String? // JSON: { itemKey: true, ... }
  consultingNotes     String?
  meetings            String? // JSON: [{ id, title, type(online|offline), scheduledAt, location, status }]

  // ── 회원 연결 (로그인 상태로 제출 시). 비회원은 null ──
  memberId String?
  member   Member? @relation(fields: [memberId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  submittedAt DateTime?

  @@index([diagnosisStatus])
  @@index([productCategory])
  @@index([submittedAt])
  @@map("export_diagnosis_requests")
}

// 회원가입 (이름 · 회사명 · 이메일 · 전화번호 · 비밀번호)
model Member {
  id           String   @id @default(cuid())
  name         String
  companyName  String
  email        String   @unique
  phone        String
  passwordHash String
  createdAt    DateTime @default(now())
  lastLoginAt  DateTime?
  roadmapProgress String? // JSON: { "<stepId>": { "done": bool, "doneAt": iso } }

  diagnoses ExportDiagnosisRequest[]

  @@index([createdAt])
  @@map("members")
}
