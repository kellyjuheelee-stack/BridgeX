# Copy to .env and adjust.
# SQLite (MVP):
DATABASE_URL="file:./dev.db"
# PostgreSQL (production): see prisma/schema.prisma header for the one-line switch.
# DATABASE_URL="postgresql://user:password@localhost:5432/bridgex?schema=public"
PORT=4000
CORS_ORIGIN="*"

# 관리자 인증
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="12h"

# 이메일 (SMTP_HOST 비우면 콘솔 로그로 대체)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="BridgeX <no-reply@bridgex.co>"
ADMIN_NOTIFY_EMAIL="admin@bridgex.co"
ADMIN_URL="http://localhost:4599/admin.html"
